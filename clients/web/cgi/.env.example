# LinkLedger CGI-Style (.env)
# =========================
# Kopiere diese Datei nach ".env" und passe die Werte an.

APP_DEBUG=true
APP_DEBUG_CONSOLE=true

# Wenn du die App unter /linkledger/ betreibst:
APP_BASE_PATH=/linkledger

# (optional) Logfile (wenn der Webspace beschreibbar ist)
APP_LOG_FILE=storage/logs/app.log

DB_HOST=127.0.0.1
DB_NAME=linkledger
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4
