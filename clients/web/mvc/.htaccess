\
# .htaccess im Code-Root
# ----------------------
# Alle Requests, die nicht auf eine echte Datei / ein echtes Verzeichnis zeigen,
# werden auf index.php umgeschrieben.

RewriteEngine On

RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

RewriteRule ^ index.php [L,QSA]
