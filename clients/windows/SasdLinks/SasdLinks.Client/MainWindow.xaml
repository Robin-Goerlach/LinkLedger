<Window x:Class="SasdLinks.Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SASD Links (Wunderlist-Style Demo)"
        Height="720" Width="1200"
        WindowStartupLocation="CenterScreen">

    <!-- Shortcuts -->
    <Window.InputBindings>
        <KeyBinding Key="F5" Command="{Binding SyncCommand}" />
        <KeyBinding Key="S" Modifiers="Control" Command="{Binding SaveLinkCommand}" />
        <KeyBinding Key="N" Modifiers="Control" Command="{Binding AddProjectCommand}" />
        <KeyBinding Key="L" Modifiers="Control" Command="{Binding AddLinkCommand}" />
        <KeyBinding Key="Delete" Command="{Binding DeleteLinkCommand}" />
    </Window.InputBindings>

    <DockPanel>
        <!-- Menu -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_Datei">
                <MenuItem Header="_Synchronisieren" InputGestureText="F5" Command="{Binding SyncCommand}" />
                <Separator/>
                <MenuItem Header="_Export">
                    <MenuItem Header="Export Snapshot (JSON)..." Command="{Binding ExportJsonCommand}" />
                    <MenuItem Header="Export Links (CSV)..." Command="{Binding ExportCsvCommand}" />
                </MenuItem>
                <MenuItem Header="_Import (Platzhalter)..." Command="{Binding ImportCommand}" />
                <Separator/>
                <MenuItem Header="_Beenden" Command="{Binding ExitCommand}" />
            </MenuItem>

            <MenuItem Header="_Bearbeiten">
                <MenuItem Header="Neues Projekt" InputGestureText="Ctrl+N" Command="{Binding AddProjectCommand}" />
                <MenuItem Header="Neuer Link" InputGestureText="Ctrl+L" Command="{Binding AddLinkCommand}" />
                <MenuItem Header="Speichern" InputGestureText="Ctrl+S" Command="{Binding SaveLinkCommand}" />
                <MenuItem Header="Löschen" InputGestureText="Del" Command="{Binding DeleteLinkCommand}" />
            </MenuItem>

            <MenuItem Header="_Ansicht">
                <MenuItem Header="Suche leeren" Command="{Binding ClearSearchCommand}" />
                <MenuItem Header="Filter zurücksetzen" Command="{Binding ResetFilterCommand}" />
            </MenuItem>

            <MenuItem Header="_Hilfe">
                <MenuItem Header="Über..." Command="{Binding AboutCommand}" />
            </MenuItem>
        </Menu>

        <!-- Ribbon-like Toolbars -->
        <ToolBarTray DockPanel.Dock="Top">
            <ToolBar Header="Start">
                <Button Content="Neues Projekt" Command="{Binding AddProjectCommand}" />
                <Button Content="Neuer Link" Command="{Binding AddLinkCommand}" />
                <Separator/>
                <Button Content="Speichern" Command="{Binding SaveLinkCommand}" />
                <Button Content="Löschen" Command="{Binding DeleteLinkCommand}" />
            </ToolBar>

            <ToolBar Header="Sync & Daten">
                <Button Content="Sync" Command="{Binding SyncCommand}" />
                <Separator/>
                <Button Content="Export JSON" Command="{Binding ExportJsonCommand}" />
                <Button Content="Export CSV" Command="{Binding ExportCsvCommand}" />
            </ToolBar>

            <ToolBar Header="Ansicht">
                <Button Content="Suche leeren" Command="{Binding ClearSearchCommand}" />
                <Button Content="Filter reset" Command="{Binding ResetFilterCommand}" />
            </ToolBar>
        </ToolBarTray>

        <!-- Status Bar -->
        <StatusBar DockPanel.Dock="Bottom">
            <TextBlock Text="{Binding Status}" />
        </StatusBar>

        <!-- Main 3-pane UI -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="380"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Projects -->
            <Border Grid.Column="0" Background="#FF1F2937" Padding="12">
                <DockPanel LastChildFill="True">
                    <TextBlock DockPanel.Dock="Top" Text="Projekte" Foreground="White"
                               FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>

                    <StackPanel DockPanel.Dock="Bottom" Margin="0,10,0,0">
                        <TextBox Text="{Binding NewProjectName, UpdateSourceTrigger=PropertyChanged}"
                                 Height="30" Margin="0,0,0,6"
                                 Background="#FF111827" Foreground="White" BorderBrush="#FF374151"
                                 Padding="8" />
                        <StackPanel Orientation="Horizontal">
                            <Button Content="+" Width="40" Height="30" Margin="0,0,6,0"
                                    Command="{Binding AddProjectCommand}" />
                            <Button Content="Löschen" Height="30"
                                    Command="{Binding DeleteProjectCommand}" />
                        </StackPanel>
                    </StackPanel>

                    <ListBox ItemsSource="{Binding Projects}" SelectedItem="{Binding SelectedProject}"
                             Background="#FF111827" BorderBrush="#FF374151" Foreground="White">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}" Padding="8"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- Middle: Links -->
            <Border Grid.Column="1" Background="#FFF8FAFC" Padding="12">
                <DockPanel LastChildFill="True">
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBox Width="280" Height="30" Margin="0,0,10,0"
                                 Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="8" />
                        <ComboBox Width="180" Height="30" Margin="0,0,10,0"
                                  ItemsSource="{Binding Tags}"
                                  SelectedItem="{Binding FilterTag}"
                                  DisplayMemberPath="Name" />
                        <Button Content="Sync" Height="30" Command="{Binding SyncCommand}" />
                    </StackPanel>

                    <ListBox ItemsSource="{Binding LinksView}" SelectedItem="{Binding SelectedLink}"
                             Background="White" BorderBrush="#FFE2E8F0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Padding="8">
                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding Url}" Foreground="#FF64748B" FontSize="12"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- Right: Details -->
            <Border Grid.Column="2" Background="White" BorderBrush="#FFE2E8F0" BorderThickness="1" Padding="12">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Details" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>

                        <TextBlock Text="URL" FontWeight="SemiBold" />
                        <TextBox Text="{Binding EditUrl, UpdateSourceTrigger=PropertyChanged}" Padding="8" Margin="0,4,0,10"/>

                        <TextBlock Text="Titel" FontWeight="SemiBold" />
                        <TextBox Text="{Binding EditTitle, UpdateSourceTrigger=PropertyChanged}" Padding="8" Margin="0,4,0,10"/>

                        <TextBlock Text="Beschreibung" FontWeight="SemiBold" />
                        <TextBox Text="{Binding EditDescription, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="8" Margin="0,4,0,10" AcceptsReturn="True" Height="100"/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Button Content="Speichern" Width="120" Margin="0,0,10,0" Command="{Binding SaveLinkCommand}"/>
                            <Button Content="Neu (aus URL-Feld)" Width="160" Margin="0,0,10,0" Command="{Binding AddLinkCommand}"/>
                            <Button Content="Löschen" Width="90" Command="{Binding DeleteLinkCommand}"/>
                        </StackPanel>

                        <Separator Margin="0,6,0,10"/>

                        <TextBlock Text="Tags" FontWeight="SemiBold" />
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,10">
                            <ComboBox Width="200" Height="28"
                                      ItemsSource="{Binding Tags}"
                                      SelectedItem="{Binding TagToAdd}"
                                      DisplayMemberPath="Name" />
                            <Button Content="Hinzufügen" Margin="10,0,0,0"
                                    Command="{Binding AssignTagCommand}"/>
                        </StackPanel>

                        <ItemsControl ItemsSource="{Binding SelectedLinkTags}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#FFE2E8F0" CornerRadius="12" Padding="8" Margin="0,0,8,8">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Name}" Margin="0,0,8,0"/>
                                            <Button Content="x" Width="22" Height="22"
                                                    Command="{Binding DataContext.RemoveTagCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Separator Margin="0,10,0,10"/>

                        <TextBlock Text="Tag-Verwaltung (kompakt)" FontWeight="SemiBold" />
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,6">
                            <TextBox Width="200" Height="28" Padding="8"
                                     Text="{Binding NewTagName, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Content="+" Width="40" Margin="10,0,0,0" Command="{Binding AddTagCommand}" />
                        </StackPanel>

                        <TextBlock Text="Zum Löschen: Tag im Filter auswählen, dann 'Tag löschen'." FontSize="11" Foreground="#FF64748B"/>
                        <Button Content="Tag löschen" Width="120" Margin="0,6,0,0" Command="{Binding DeleteTagCommand}" />
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </DockPanel>
</Window>
